<div id="image-viewer" class="image-viewer">
  <img id="image-viewer-img" src="" alt="" />
</div>

<script>
  type ImageViewerController = {
    destroy: () => void
  }

  declare global {
    interface Window {
      __imageViewerController?: ImageViewerController | null
    }
  }

  function initImageViewer() {
    window.__imageViewerController?.destroy()

    const viewer = document.getElementById('image-viewer')
    const viewerImg = document.getElementById('image-viewer-img') as HTMLImageElement
    const contentArea =
      document.querySelector<HTMLElement>('.prose') ||
      document.querySelector<HTMLElement>('.content') ||
      document.querySelector<HTMLElement>('article')

    if (!viewer || !viewerImg || viewerImg.tagName !== 'IMG' || !contentArea) return

    // Display image in fullscreen viewer overlay
    function showImage(src: string, alt?: string) {
      if (viewerImg && src) {
        viewerImg.src = src
        viewerImg.alt = alt || ''
      }

      void viewer!.offsetWidth
      viewer!.classList.add('active')
      document.body.classList.add('image-viewer-open')
      document.body.style.overflow = 'hidden'
      document.body.dataset.scrollY = window.scrollY.toString()
    }

    // Hide the image viewer and restore page scroll
    function hideImage() {
      viewer!.classList.remove('active')
      document.body.classList.remove('image-viewer-open')
      document.body.style.overflow = ''
    }

    function handleContentClick(e: MouseEvent) {
      const target = e.target

      if (!(target instanceof HTMLImageElement) || target.dataset.preview !== 'true') {
        return
      }

      e.preventDefault()
      showImage(target.src, target.alt || '')
    }

    function handleViewerTransitionEnd(e: TransitionEvent) {
      if (e.propertyName === 'opacity' && !viewer!.classList.contains('active')) {
        viewerImg.src = ''
        viewerImg.alt = ''
      }
    }

    function handleViewerTouchMove(e: TouchEvent) {
      if (viewer!.classList.contains('active')) {
        e.preventDefault()
      }
    }

    function handleKeydown(e: KeyboardEvent) {
      if (e.key === 'Escape' && viewer!.classList.contains('active')) {
        hideImage()
      }
    }

    // Hide and clear image after transition ends
    viewer.addEventListener('transitionend', handleViewerTransitionEnd)

    viewer.addEventListener('click', hideImage)
    contentArea.addEventListener('click', handleContentClick)

    // Prevent touch scroll in image viewer
    viewer.addEventListener('touchmove', handleViewerTouchMove, { passive: false })

    document.addEventListener('keydown', handleKeydown)

    viewer.classList.remove('active')

    const controller: ImageViewerController = {
      destroy() {
        viewer.removeEventListener('transitionend', handleViewerTransitionEnd)
        viewer.removeEventListener('click', hideImage)
        viewer.removeEventListener('touchmove', handleViewerTouchMove)
        contentArea.removeEventListener('click', handleContentClick)
        document.removeEventListener('keydown', handleKeydown)
        document.body.classList.remove('image-viewer-open')
        document.body.style.overflow = ''
        viewer.classList.remove('active')

        if (window.__imageViewerController === controller) {
          window.__imageViewerController = null
        }
      }
    }

    window.__imageViewerController = controller
  }

  // Use only astro:page-load as it fires on initial load and navigation
  document.addEventListener('astro:page-load', initImageViewer)
</script>

<style>
  .image-viewer {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.15s ease-in-out;
    background: color-mix(in srgb, var(--bg) 90%, transparent);
  }

  .image-viewer.active {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  :global(.prose img[data-preview='true']) {
    cursor: pointer;
  }

  .image-viewer img {
    min-width: 45rem;
    max-width: 60vw;
    max-height: 80vh;
    object-fit: contain;
  }

  @media (max-width: 768px) {
    .image-viewer img {
      min-width: 100vw;
    }
  }

  body.image-viewer-open {
    overflow: hidden;
  }
</style>
