<script>
  import { fetchJsonWithCache, initOnPageLoad, setupLazyResources } from '@/utils/client/lazy-resource'

  type NeoDBData = Record<string, unknown>
  type FieldConfig = Record<string, Array<[string, (data: NeoDBData) => string]>>
  type LocalizedTitle = {
    lang?: unknown
    text?: unknown
  }

  function loadNeoDBCards() {
    const allContainers = document.querySelectorAll('.neodb-card-container')

    allContainers.forEach((container) => {
      if (!container.hasAttribute('data-url')) {
        container.remove()
      }
    })

    const containers = document.querySelectorAll('.neodb-card-container[data-url]')

    if (containers.length === 0) {
      return
    }

    const createElement = <TagName extends keyof HTMLElementTagNameMap>(tagName: TagName, className?: string) => {
      const element = document.createElement(tagName)

      if (className) {
        element.className = className
      }

      return element
    }

    const renderError = (elem: HTMLElement) => {
      const card = createElement('div', 'neodb-card error')
      const text = createElement('p', 'neodb-error')

      text.textContent = '🔴  Error'
      card.append(text)
      elem.replaceChildren(card)
    }

    const getHttpUrl = (url: string) => {
      try {
        const parsedUrl = new URL(url)

        if (parsedUrl.protocol !== 'http:' && parsedUrl.protocol !== 'https:') {
          return null
        }

        return parsedUrl
      } catch {
        return null
      }
    }

    const getSafeHttpUrl = (url: unknown) => (typeof url === 'string' ? getHttpUrl(url)?.toString() : '') ?? ''

    const getHostName = (url: URL) => url.hostname.replace(/^www\./, '').toLowerCase()

    const getNeoDBFetchUrl = (url: string) => {
      const parsedUrl = getHttpUrl(url)

      if (!parsedUrl) {
        return ''
      }

      if (getHostName(parsedUrl) === 'neodb.social') {
        const match = parsedUrl.pathname.match(/^\/(movie|book|music|album|game|tv\/season|tv|podcast)\/([\w-]+)/)
        const category = match ? match[1] : ''
        const uuid = match ? match[2] : ''

        return category && uuid ? `https://neodb.social/api/${category}/${uuid}` : ''
      }

      return `https://neodb.social/api/catalog/fetch?url=${encodeURIComponent(parsedUrl.toString())}`
    }

    const getNeoDBData = (fetchUrl: string) => {
      return fetchJsonWithCache<NeoDBData>({
        cacheName: 'neodb',
        cacheKey: fetchUrl,
        url: fetchUrl,
        init: {
          mode: 'cors',
          headers: {
            Accept: 'application/json'
          }
        },
        transform: (json) => {
          if (json && typeof json === 'object' && 'data' in json) {
            const value = (json as { data?: unknown }).data

            return value && typeof value === 'object' ? (value as NeoDBData) : {}
          }

          return json && typeof json === 'object' ? (json as NeoDBData) : {}
        }
      })
    }

    const toText = (value: unknown) => {
      if (typeof value === 'string') {
        return value.trim()
      }

      if (typeof value === 'number') {
        return String(value)
      }

      return ''
    }

    const toTextList = (value: unknown) => {
      const values = Array.isArray(value) ? value : [value]

      return values.map(toText).filter(Boolean)
    }

    const getJoinedText = (value: unknown) => toTextList(value).join(', ')

    const getFirstText = (value: unknown) => toTextList(value)[0] ?? ''

    const fieldConfig: FieldConfig = {
      movie: [
        ['导演', (data) => getJoinedText(data.director)],
        ['演员', (data) => getJoinedText(data.actor)],
        ['类型', (data) => getJoinedText(data.genre)],
        ['上映时间', (data) => toText(data.year)]
      ],
      tv: [
        ['导演', (data) => getJoinedText(data.director)],
        ['演员', (data) => getJoinedText(data.actor)],
        ['类型', (data) => getJoinedText(data.genre)],
        ['首播', (data) => toText(data.year)]
      ],
      'tv/season': [
        ['导演', (data) => getJoinedText(data.director)],
        ['演员', (data) => getJoinedText(data.actor)],
        ['类型', (data) => getJoinedText(data.genre)],
        ['首播', (data) => toText(data.year)]
      ],
      music: [
        ['艺术家', (data) => getFirstText(data.artist)],
        ['流派', (data) => getJoinedText(data.genre)],
        ['发行时间', (data) => toText(data.release_date)]
      ],
      album: [
        ['艺术家', (data) => getFirstText(data.artist)],
        ['流派', (data) => getJoinedText(data.genre)],
        ['发行时间', (data) => toText(data.release_date)]
      ],
      book: [
        ['作者', (data) => getJoinedText(data.author)],
        ['出版社', (data) => getJoinedText(data.publisher || data.pub_house || data.company)]
      ],
      game: [
        ['开发者', (data) => getJoinedText(data.developer)],
        ['类型', (data) => getJoinedText(data.genre)],
        ['发行时间', (data) => toText(data.release_date)]
      ],
      podcast: [
        ['主播', (data) => getJoinedText(data.host || data.artist || data.creator)],
        ['类型', (data) => getJoinedText(data.genre)]
      ]
    }

    const isLocalizedTitle = (value: unknown): value is LocalizedTitle => {
      return Boolean(value && typeof value === 'object')
    }

    const findLocalizedTitle = (titles: unknown[], lang: string | null) => {
      return titles.find((title): title is LocalizedTitle => {
        if (!isLocalizedTitle(title) || !toText(title.text)) {
          return false
        }

        return lang === null ? title.lang !== 'zh-cn' : title.lang === lang
      })
    }

    const getPreferredTitle = (data: NeoDBData, category: string) => {
      if (category === 'music' || category === 'album') {
        const localizedTitles = Array.isArray(data.localized_title) ? data.localized_title : []
        const nonZhTitle = findLocalizedTitle(localizedTitles, null)
        const zhTitle = findLocalizedTitle(localizedTitles, 'zh-cn')

        return toText(nonZhTitle?.text) || toText(zhTitle?.text) || toText(data.title || data.name)
      }

      return toText(data.title || data.name)
    }

    const getFieldInfo = (data: NeoDBData, category: string) => {
      const fields = fieldConfig[category] ?? []

      return fields.map(([label, getValue]) => [label, getValue(data)]).filter(([, value]) => value)
    }

    const createRating = (rating: unknown) => {
      const ratingElement = createElement('div', 'rating')
      const itemRating = Number.parseFloat(toText(rating))

      if (Number.isFinite(itemRating) && itemRating > 0) {
        const background = createElement('span', 'allstarbg')
        const foreground = createElement('span', 'allstarfg')
        const ratingNums = createElement('span', 'rating_nums')
        const starPercentage = Math.max(0, Math.min(100, Math.round((itemRating / 10) * 10) * 10))

        foreground.style.width = `${starPercentage}%`
        ratingNums.textContent = itemRating.toFixed(1)
        background.append(foreground)
        ratingElement.append(background, ratingNums)

        return ratingElement
      }

      ratingElement.append(createElement('span', 'allstargray'))
      return ratingElement
    }

    const renderCard = (elem: HTMLElement, data: NeoDBData, targetUrl: string) => {
      const safeTargetUrl = getSafeHttpUrl(targetUrl)

      if (!safeTargetUrl) {
        renderError(elem)
        return
      }

      const cardData = data && typeof data === 'object' ? (data as NeoDBData) : {}
      const category = toText(cardData.category)
      const title = getPreferredTitle(cardData, category)
      const coverUrl = getSafeHttpUrl(cardData.cover_image_url || cardData.cover_url)
      const isSquare = category === 'music' || category === 'podcast'
      const coverClass = isSquare ? 'music' : 'other'
      const cardHeightClass = isSquare ? 'compact' : 'standard'
      const card = createElement('a', `neodb-card ${cardHeightClass}`)
      const info = createElement('div', 'neodb-info')
      const titleElement = createElement('div', 'neodb-title')

      card.href = safeTargetUrl
      card.target = '_blank'
      card.rel = 'noopener noreferrer'

      if (coverUrl) {
        const cover = createElement('img', `neodb-cover ${coverClass}`)

        cover.src = coverUrl
        cover.alt = title
        cover.loading = 'lazy'
        card.append(cover)
      } else {
        const cover = createElement('div', `neodb-cover ${coverClass}`)

        cover.style.background = '#f3f4f6'
        card.append(cover)
      }

      titleElement.textContent = title
      info.append(titleElement, createRating(cardData.rating))

      getFieldInfo(cardData, category).forEach(([label, value]) => {
        const field = createElement('div', 'neodb-field')

        field.textContent = `${label}: ${value}`
        info.append(field)
      })

      card.append(info)
      elem.replaceChildren(card)
    }

    const loadCard = async (container: HTMLElement) => {
      const url = container.getAttribute('data-url')

      if (!url) {
        throw new Error('Missing NeoDB URL')
      }

      const fetchUrl = getNeoDBFetchUrl(url)

      if (!fetchUrl) {
        throw new Error('Invalid NeoDB URL')
      }

      const data = await getNeoDBData(fetchUrl)
      renderCard(container, data, url)
    }

    setupLazyResources({
      key: 'neodb-cards',
      selector: '.neodb-card-container[data-url]',
      stateKey: 'neodbState',
      load: loadCard,
      onError: renderError
    })
  }

  initOnPageLoad('neodb-cards', loadNeoDBCards)
</script>

<style is:inline>
